# ============ Database ============
DATABASE_URL="postgresql://user:password@localhost:5432/ilal_saas"

# ============ JWT (REQUIRED - no defaults) ============
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ============ API Key (REQUIRED - no defaults) ============
API_KEY_SECRET="your-super-secret-api-key-salt-change-in-production"

# ============ Server ============
PORT=3001
NODE_ENV="development"

# ============ Blockchain ============
RPC_URL="https://base-sepolia-rpc.publicnode.com"
CHAIN_ID=84532
VERIFIER_PRIVATE_KEY="0x..."

# Contract addresses
SESSION_MANAGER_ADDRESS="0x..."
VERIFIER_ADDRESS="0x..."
SIMPLE_SWAP_ROUTER_ADDRESS="0x..."
POOL_MANAGER_ADDRESS="0x..."
POSITION_MANAGER_ADDRESS="0x..."
COMPLIANCE_HOOK_ADDRESS="0x..."

# ============ ZK Verification (REQUIRED in production) ============
EXPECTED_MERKLE_ROOT="<decimal string of the trusted Merkle root>"
EXPECTED_ISSUER_AX="<decimal string of EdDSA issuer public key Ax>"
EXPECTED_ISSUER_AY="<decimal string of EdDSA issuer public key Ay>"

# ============ Rate Limiting ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_FREE=10
RATE_LIMIT_MAX_REQUESTS_PRO=100
RATE_LIMIT_MAX_REQUESTS_ENTERPRISE=1000

