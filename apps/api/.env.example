# ============ Database ============
DATABASE_URL="postgresql://user:password@localhost:5432/ilal_saas"

# ============ JWT (REQUIRED - no defaults) ============
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-separate-refresh-token-secret-change-in-production"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ============ API Key (REQUIRED - no defaults) ============
API_KEY_SECRET="your-super-secret-api-key-salt-change-in-production"

# ============ Server ============
PORT=3001
NODE_ENV="development"

# ============ Blockchain ============
RPC_URL="https://base-sepolia-rpc.publicnode.com"
CHAIN_ID=84532
VERIFIER_PRIVATE_KEY="0x..."

# Contract addresses
SESSION_MANAGER_ADDRESS="0x..."
VERIFIER_ADDRESS="0x..."
SIMPLE_SWAP_ROUTER_ADDRESS="0x..."
POOL_MANAGER_ADDRESS="0x..."
POSITION_MANAGER_ADDRESS="0x..."
COMPLIANCE_HOOK_ADDRESS="0x..."

# ============ ZK Verification (REQUIRED in production) ============
EXPECTED_MERKLE_ROOT="<decimal string of the trusted Merkle root>"
EXPECTED_MERKLE_ROOT_PREV=""  # Previous root, accepted during tree rotation
EXPECTED_ISSUER_AX="<decimal string of EdDSA issuer public key Ax>"
EXPECTED_ISSUER_AY="<decimal string of EdDSA issuer public key Ay>"

# ============ Rate Limiting ============
# Set RATE_LIMIT_DEV_OVERRIDE=true to relax limits in development
RATE_LIMIT_DEV_OVERRIDE="false"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_FREE=10
RATE_LIMIT_MAX_REQUESTS_PRO=100
RATE_LIMIT_MAX_REQUESTS_ENTERPRISE=1000

# ============ Email (optional) ============
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="noreply@ilal.xyz"
# SMTP_PASS="..."
# SMTP_FROM="ILAL <noreply@ilal.xyz>"

# ============ Sentry (optional) ============
# SENTRY_DSN="https://..."

# ============ API Endpoints Reference ============
# Auth (JWT):
#   POST /api/v1/auth/register         - Register new user
#   POST /api/v1/auth/login            - Login, get tokens
#   POST /api/v1/auth/refresh          - Refresh access token
#   GET  /api/v1/auth/me               - Get current user (JWT)
#
# API Keys (JWT):
#   GET    /api/v1/apikeys             - List API keys
#   POST   /api/v1/apikeys            - Create API key
#   DELETE /api/v1/apikeys/:id        - Delete API key
#
# Compliance Session:
#   POST /api/v1/verify               - Verify ZK proof & activate session (API Key)
#   POST /api/v1/verify/renew         - Renew active session without ZK proof (JWT)
#   GET  /api/v1/verify/session       - Get session status by address (JWT)
#                                       Query param: ?address=0x...
#   GET  /api/v1/session/:address     - Get session status (public, no auth)
#
# DeFi (API Key or JWT):
#   POST /api/v1/defi/swap            - Build unsigned swap tx
#   POST /api/v1/defi/liquidity       - Build unsigned add-liquidity tx
#
# Usage & Billing (JWT):
#   GET  /api/v1/usage/stats          - Usage statistics
#   GET  /api/v1/billing/plans        - Available plans (public)
#   POST /api/v1/billing/upgrade      - Upgrade plan
